+data class PlaylistCreator(
+    @SerializedName("nickname") val nickname: String,
+    @SerializedName("userId") val userId: Long
+)
+
+data class PlaylistDetailResponse(
+    @SerializedName("code") val code: Int,
+    @SerializedName("playlist") val playlist: PlaylistDetail?
+)
+
+data class PlaylistDetail(
+    @SerializedName("id") val id: Long,
+    @SerializedName("name") val name: String,
+    @SerializedName("tracks") val tracks: List<NeteaseTrack>?,
+    @SerializedName("trackCount") val trackCount: Int?,
+    @SerializedName("coverImgUrl") val coverImgUrl: String?
+)
+
+// ----- Track -----
+data class NeteaseTrack(
+    @SerializedName("id") val id: Long,
+    @SerializedName("name") val name: String,
+    @SerializedName("ar") val artists: List<NeteaseArtist>?,
+    @SerializedName("al") val album: NeteaseAlbum?,
+    @SerializedName("dt") val duration: Long?
+) {
+    fun toSong(source: String = "netease"): Song = Song(
+        id = this.id,
+        name = this.name,
+        artist = this.artists?.map { it.name },
+        album = this.album?.name,
+        picId = this.album?.id?.toString(),
+        urlId = this.id.toString(),
+        lyricId = this.id.toString(),
+        source = source
+    )
+}
+
+data class NeteaseArtist(
+    @SerializedName("id") val id: Long,
+    @SerializedName("name") val name: String
+)
+
+data class NeteaseAlbum(
+    @SerializedName("id") val id: Long,
+    @SerializedName("name") val name: String,
+    @SerializedName("picUrl") val picUrl: String?
+)
+
