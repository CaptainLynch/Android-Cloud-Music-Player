+package com.lynchlin.music.network
+
+import com.lynchlin.music.data.model.netease.*
+import retrofit2.http.Body
+import retrofit2.http.GET
+import retrofit2.http.POST
+import retrofit2.http.Query
+
+interface NeteaseApiService {
+
+    @POST("login/cellphone")
+    suspend fun loginByPhone(
+        @Body body: Map<String, String>
+    ): LoginResponse
+
+    @POST("login/email")
+    suspend fun loginByEmail(
+        @Body body: Map<String, String>
+    ): LoginResponse
+
+    @GET("login/status")
+    suspend fun getLoginStatus(): LoginStatusResponse
+
+    @GET("user/playlist")
+    suspend fun getUserPlaylist(
+        @Query("uid") uid: Long,
+        @Query("limit") limit: Int = 50,
+        @Query("offset") offset: Int = 0
+    ): UserPlaylistResponse
+
+    @GET("playlist/detail")
+    suspend fun getPlaylistDetail(
+        @Query("id") id: Long
+    ): PlaylistDetailResponse
+
+    @GET("recommend/songs")
+    suspend fun getDailyRecommend(): DailyRecommendResponse
+
+    @GET("personal_fm")
+    suspend fun getPersonalFm(): PersonalFmResponse
+}
