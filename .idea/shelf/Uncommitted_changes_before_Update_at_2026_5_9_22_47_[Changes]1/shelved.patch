+import coil.compose.AsyncImage
+import com.lynchlin.music.data.model.netease.NeteasePlaylist
+import com.lynchlin.music.data.model.netease.NeteaseTrack
+import com.lynchlin.music.ui.availablePlatforms
+
+@OptIn(ExperimentalMaterial3Api::class)
+@Composable
+fun PlaylistScreen(
+    userId: Long,
+    onBack: () -> Unit,
+    onOpenPlayer: () -> Unit,
+    viewModel: PlaylistViewModel = viewModel()
+) {
+    val uiState by viewModel.uiState.collectAsState()
+
+    LaunchedEffect(userId) {
+        if (uiState.playlists.isEmpty() && uiState.error == null) {
+            viewModel.loadUserPlaylists(userId)
+        }
+    }
+
+    Scaffold(
+        topBar = {
+            TopAppBar(
+                title = {
+                    Text(uiState.selectedPlaylistName ?: "My Playlists")
+                },
+                navigationIcon = {
+                    IconButton(onClick = {
+                        if (uiState.selectedPlaylistTracks != null) {
+                            viewModel.clearSelectedPlaylist()
+                        } else {
+                            onBack()
+                        }
+                    }) {
+                        Icon(Icons.AutoMirrored.Filled.ArrowBack, contentDescription = "Back")
+                    }
+                },
+                actions = {
+                    if (uiState.selectedPlaylistTracks == null && uiState.dailySongs == null) {
+                        TextButton(onClick = { viewModel.loadDailyRecommend() }) {
+                            Text("Daily")
+                        }
+                    }
+                }
+            )
+        }
+    ) { padding ->
+        Column(
+            modifier = Modifier
+                .fillMaxSize()
+                .padding(padding)
+        ) {
+            when {
+                uiState.isLoading -> {
+                    Box(Modifier.fillMaxSize(), contentAlignment = Alignment.Center) {
+                        CircularProgressIndicator()
+                    }
+                }
+                uiState.error != null -> {
+                    Box(Modifier.fillMaxSize(), contentAlignment = Alignment.Center) {
+                        Text("Error: ${uiState.error}", color = MaterialTheme.colorScheme.error)
+                    }
+                }
+                uiState.selectedPlaylistTracks != null -> {
+                    TrackList(
+                        tracks = uiState.selectedPlaylistTracks!!,
+                        playlistName = uiState.selectedPlaylistName ?: "",
+                        onPlayTrack = { idx -> viewModel.playTracks(uiState.selectedPlaylistTracks!!, idx) },
+                        onPlayAll = { viewModel.playTracks(uiState.selectedPlaylistTracks!!) }
+                    )
+                }
+                uiState.dailySongs != null -> {
+                    TrackList(
+                        tracks = uiState.dailySongs!!,
+                        playlistName = "Daily Recommend",
+                        onPlayTrack = { idx -> viewModel.playTracks(uiState.dailySongs!!, idx) },
+                        onPlayAll = { viewModel.playTracks(uiState.dailySongs!!) }
+                    )
+                }
+                else -> {
+                    PlaylistGrid(
+                        playlists = uiState.playlists,
+                        onPlaylistClick = { pl ->
+                            viewModel.loadPlaylistDetail(pl.id, pl.name)
+                        }
+                    )
+                }
+            }
+        }
+    }
