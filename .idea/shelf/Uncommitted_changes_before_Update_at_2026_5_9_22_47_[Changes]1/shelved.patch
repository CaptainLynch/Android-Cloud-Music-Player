+package com.lynchlin.music.ui.auth
+
+import android.app.Application
+import androidx.lifecycle.AndroidViewModel
+import androidx.lifecycle.viewModelScope
+import com.lynchlin.music.data.model.netease.UserProfile
+import com.lynchlin.music.network.NeteaseRetrofitClient
+import kotlinx.coroutines.flow.MutableStateFlow
+import kotlinx.coroutines.flow.StateFlow
+import kotlinx.coroutines.flow.asStateFlow
+import kotlinx.coroutines.launch
+
+enum class LoginMethod { PHONE, EMAIL }
+
+data class LoginUiState(
+    val isLoading: Boolean = false,
+    val error: String? = null,
+    val isLoggedIn: Boolean = false,
+    val userProfile: UserProfile? = null,
+    val loginMethod: LoginMethod = LoginMethod.PHONE
+)
+
+class LoginViewModel(application: Application) : AndroidViewModel(application) {
+
+    private val _uiState = MutableStateFlow(LoginUiState())
+    val uiState: StateFlow<LoginUiState> = _uiState.asStateFlow()
+
+    init {
+        checkLoginStatus()
+    }
+
+    fun setLoginMethod(method: LoginMethod) {
+        _uiState.value = _uiState.value.copy(loginMethod = method)
+    }
+
+    fun loginByPhone(phone: String, password: String) {
+        if (phone.isBlank() || password.isBlank()) {
+            _uiState.value = _uiState.value.copy(error = "Phone and password required")
+            return
+        }
+
+        viewModelScope.launch {
+            _uiState.value = _uiState.value.copy(isLoading = true, error = null)
+            try {
+                val body = mapOf("phone" to phone, "password" to password)
+                val response = NeteaseRetrofitClient.apiService.loginByPhone(body)
+                if (response.code == 200) {
+                    response.cookie?.let { NeteaseRetrofitClient.saveCookie(it) }
+                    _uiState.value = _uiState.value.copy(
+                        isLoggedIn = true,
+                        userProfile = response.profile,
+                        isLoading = false
+                    )
+                } else {
+                    _uiState.value = _uiState.value.copy(
+                        error = "Login failed (${response.code})",
+                        isLoading = false
+                    )
+                }
+            } catch (e: Exception) {
+                _uiState.value = _uiState.value.copy(
+                    error = e.message ?: "Network error",
+                    isLoading = false
+                )
+            }
+        }
+    }
+
+    fun loginByEmail(email: String, password: String) {
+        if (email.isBlank() || password.isBlank()) {
+            _uiState.value = _uiState.value.copy(error = "Email and password required")
+            return
+        }
+
+        viewModelScope.launch {
+            _uiState.value = _uiState.value.copy(isLoading = true, error = null)
+            try {
+                val body = mapOf("email" to email, "password" to password)
+                val response = NeteaseRetrofitClient.apiService.loginByEmail(body)
+                if (response.code == 200) {
+                    response.cookie?.let { NeteaseRetrofitClient.saveCookie(it) }
+                    _uiState.value = _uiState.value.copy(
+                        isLoggedIn = true,
+                        userProfile = response.profile,
+                        isLoading = false
+                    )
+                } else {
+                    _uiState.value = _uiState.value.copy(
+                        error = "Login failed (${response.code})",
+                        isLoading = false
+                    )
+                }
+            } catch (e: Exception) {
+                _uiState.value = _uiState.value.copy(
+                    error = e.message ?: "Network error",
+                    isLoading = false
+                )
+            }
+        }
+    }
+
+    fun logout() {
+        NeteaseRetrofitClient.clearCookie()
+        _uiState.value = LoginUiState()
+    }
+
+    private fun checkLoginStatus() {
+        if (!NeteaseRetrofitClient.isLoggedIn) return
+        viewModelScope.launch {
+            try {
+                val resp = NeteaseRetrofitClient.apiService.getLoginStatus()
+                if (resp.code == 200 && resp.profile != null) {
+                    _uiState.value = _uiState.value.copy(
+                        isLoggedIn = true,
+                        userProfile = resp.profile
+                    )
+                } else {
+                    NeteaseRetrofitClient.clearCookie()
+                }
+            } catch (_: Exception) {
+                // silent fail — user can re-login
+            }
+        }
+    }
+}
