+package com.lynchlin.music.ui.playlist
+
+import android.app.Application
+import androidx.lifecycle.AndroidViewModel
+import androidx.lifecycle.viewModelScope
+import com.lynchlin.music.data.model.Song
+import com.lynchlin.music.data.model.netease.NeteasePlaylist
+import com.lynchlin.music.data.model.netease.NeteaseTrack
+import com.lynchlin.music.network.NeteaseRetrofitClient
+import com.lynchlin.music.player.MusicPlayerManager
+import kotlinx.coroutines.flow.MutableStateFlow
+import kotlinx.coroutines.flow.StateFlow
+import kotlinx.coroutines.flow.asStateFlow
+import kotlinx.coroutines.launch
+
+data class PlaylistUiState(
+    val isLoading: Boolean = false,
+    val error: String? = null,
+    val playlists: List<NeteasePlaylist> = emptyList(),
+    val selectedPlaylistTracks: List<NeteaseTrack>? = null,
+    val selectedPlaylistName: String? = null,
+    val dailySongs: List<NeteaseTrack>? = null
+)
+
+class PlaylistViewModel(application: Application) : AndroidViewModel(application) {
+
+    private val _uiState = MutableStateFlow(PlaylistUiState())
+    val uiState: StateFlow<PlaylistUiState> = _uiState.asStateFlow()
+
+    fun loadUserPlaylists(userId: Long) {
+        viewModelScope.launch {
+            _uiState.value = _uiState.value.copy(isLoading = true, error = null)
+            try {
+                val response = NeteaseRetrofitClient.apiService.getUserPlaylist(uid = userId)
+                if (response.code == 200 && response.playlist != null) {
+                    _uiState.value = _uiState.value.copy(
+                        playlists = response.playlist,
+                        isLoading = false
+                    )
+                } else {
+                    _uiState.value = _uiState.value.copy(
+                        error = "Failed to load playlists (${response.code})",
+                        isLoading = false
+                    )
+                }
+            } catch (e: Exception) {
+                _uiState.value = _uiState.value.copy(
+                    error = e.message ?: "Network error",
+                    isLoading = false
+                )
+            }
+        }
+    }
+
+    fun loadPlaylistDetail(playlistId: Long, playlistName: String) {
+        viewModelScope.launch {
+            _uiState.value = _uiState.value.copy(isLoading = true, error = null)
+            try {
+                val response = NeteaseRetrofitClient.apiService.getPlaylistDetail(id = playlistId)
+                if (response.code == 200 && response.playlist?.tracks != null) {
+                    _uiState.value = _uiState.value.copy(
+                        selectedPlaylistTracks = response.playlist.tracks,
+                        selectedPlaylistName = playlistName,
+                        isLoading = false
+                    )
+                } else {
+                    _uiState.value = _uiState.value.copy(
+                        error = "Failed to load playlist (${response.code})",
+                        isLoading = false
+                    )
+                }
+            } catch (e: Exception) {
+                _uiState.value = _uiState.value.copy(
+                    error = e.message ?: "Network error",
+                    isLoading = false
+                )
+            }
+        }
+    }
+
+    fun loadDailyRecommend() {
+        viewModelScope.launch {
+            _uiState.value = _uiState.value.copy(isLoading = true, error = null)
+            try {
+                val response = NeteaseRetrofitClient.apiService.getDailyRecommend()
+                if (response.code == 200 && response.data?.dailySongs != null) {
+                    _uiState.value = _uiState.value.copy(
+                        dailySongs = response.data.dailySongs,
+                        isLoading = false
+                    )
+                } else {
+                    _uiState.value = _uiState.value.copy(
+                        error = "Failed to load daily recommend (${response.code})",
+                        isLoading = false
+                    )
+                }
+            } catch (e: Exception) {
+                _uiState.value = _uiState.value.copy(
+                    error = e.message ?: "Network error",
+                    isLoading = false
+                )
+            }
+        }
+    }
+
+    fun playTrack(track: NeteaseTrack) {
+        val song = track.toSong()
+        MusicPlayerManager.playQueue(listOf(song), 0)
+    }
+
+    fun playTracks(tracks: List<NeteaseTrack>, startIndex: Int = 0) {
+        val songs = tracks.map { it.toSong() }
+        MusicPlayerManager.playQueue(songs, startIndex)
+    }
+
+    fun clearSelectedPlaylist() {
+        _uiState.value = _uiState.value.copy(
+            selectedPlaylistTracks = null,
+            selectedPlaylistName = null
+        )
+    }
+}
