+package com.lynchlin.music.network
+
+import android.content.Context
+import android.content.SharedPreferences
+import okhttp3.Interceptor
+import okhttp3.OkHttpClient
+import okhttp3.logging.HttpLoggingInterceptor
+import retrofit2.Retrofit
+import retrofit2.converter.gson.GsonConverterFactory
+
+object NeteaseRetrofitClient {
+
+    var baseUrl: String = "http://10.0.2.2:3000/"
+        private set
+
+    private lateinit var cookiePrefs: SharedPreferences
+    private var initialized = false
+
+    private val loggingInterceptor = HttpLoggingInterceptor().apply {
+        level = HttpLoggingInterceptor.Level.BODY
+    }
+
+    private val cookieInterceptor = Interceptor { chain ->
+        val request = chain.request()
+        val cookie = getSavedCookie()
+        val newRequest = if (cookie != null) {
+            request.newBuilder()
+                .header("Cookie", cookie)
+                .build()
+        } else {
+            request
+        }
+        val response = chain.proceed(newRequest)
+        response.header("Set-Cookie")?.let { setCookie ->
+            val existing = getSavedCookie() ?: ""
+            val allCookies = if (existing.isNotEmpty() && !existing.contains(setCookie.split(";")[0])) {
+                "$existing; $setCookie"
+            } else {
+                setCookie
+            }
+            saveCookie(allCookies)
+        }
+        response
+    }
+
+    private val okHttpClient = OkHttpClient.Builder()
+        .addInterceptor(loggingInterceptor)
+        .addInterceptor(cookieInterceptor)
+        .build()
+
+    val apiService: NeteaseApiService by lazy {
+        Retrofit.Builder()
+            .baseUrl(baseUrl)
+            .client(okHttpClient)
+            .addConverterFactory(GsonConverterFactory.create())
+            .build()
+            .create(NeteaseApiService::class.java)
+    }
+
+    fun init(context: Context, serverUrl: String? = null) {
+        if (initialized) return
+        cookiePrefs = context.getSharedPreferences("netease_cookies", Context.MODE_PRIVATE)
+        serverUrl?.let { baseUrl = it }
+        initialized = true
+    }
+
+    fun setServerUrl(url: String) {
+        baseUrl = url.trimEnd('/') + "/"
+    }
+
+    fun getSavedCookie(): String? {
+        if (!::cookiePrefs.isInitialized) return null
+        return cookiePrefs.getString("music_u_cookie", null)
+    }
+
+    fun saveCookie(cookie: String) {
+        if (!::cookiePrefs.isInitialized) return
+        cookiePrefs.edit().putString("music_u_cookie", cookie).apply()
+    }
+
+    fun clearCookie() {
+        if (!::cookiePrefs.isInitialized) return
+        cookiePrefs.edit().remove("music_u_cookie").apply()
+    }
+
+    val isLoggedIn: Boolean
+        get() = getSavedCookie()?.let { it.contains("MUSIC_U") || it.contains("__remember_me") } == true
+}
